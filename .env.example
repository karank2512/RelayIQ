# ── RelayIQ environment (copy to .env — never commit .env) ─────────────────
# All secrets below are development placeholders. Generate real values with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# Core
RELAYIQ_ENV=development
RELAYIQ_LOG_LEVEL=INFO
RELAYIQ_API_HOST=0.0.0.0
RELAYIQ_API_PORT=8000

# Database (PostgreSQL is the source of truth)
# Compose publishes the container on host port 5433 to avoid clashing with local Postgres installs
DATABASE_URL=postgresql+psycopg://relayiq:relayiq_dev_password@localhost:5433/relayiq

# Redis (cache + Celery broker/result backend)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Auth — dev JWT signing secret (HS256). Replace in any real deployment.
RELAYIQ_JWT_SECRET=CHANGE_ME_generate_a_long_random_value
RELAYIQ_JWT_TTL_SECONDS=28800

# Webhook HMAC secrets (comma-separated to support rotation: newest first)
RELAYIQ_WEBHOOK_SECRETS=CHANGE_ME_webhook_secret_v2,CHANGE_ME_webhook_secret_v1
RELAYIQ_WEBHOOK_REPLAY_WINDOW_SECONDS=300

# Provider simulators
RELAYIQ_SYNTHETIC_WORLD_PATH=./data/synthetic_world.json
RELAYIQ_PROVIDER_SIM_SEED=42

# HubSpot (optional — leave blank to use the CRM simulator)
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_BASE_URL=https://api.hubapi.com

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=relayiq-api
RELAYIQ_METRICS_ENABLED=true

# Frontend
VITE_API_BASE_URL=http://localhost:8000
